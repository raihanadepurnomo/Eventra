# ─── Environment Configuration ─────────────────────────────────────────────────
# Salin file ini sebagai .env dan isi dengan nilai yang sesuai
# JANGAN commit file .env ke repository!

# ─── Database (MySQL) ───────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=eventra

# ─── JWT Secret ─────────────────────────────────────────────────────────────────
# Gunakan string acak yang panjang dan kompleks, minimal 32 karakter
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ─── Backend ────────────────────────────────────────────────────────────────────
SERVER_PORT=5000
BACKEND_URL=http://localhost:5000

# ─── Google OAuth ───────────────────────────────────────────────────────────────
# Buat credentials di: https://console.cloud.google.com/
# Authorized redirect URIs: http://localhost:5000/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── Midtrans Payment Gateway ───────────────────────────────────────────────────
# Dapatkan keys dari: https://dashboard.midtrans.com/
# Gunakan Sandbox keys untuk development, Production keys untuk live
MIDTRANS_SERVER_KEY=Mid-server-xxxxxxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=Mid-client-xxxxxxxxxxxxxxxxxxxx
MIDTRANS_IS_PRODUCTION=false

# ─── Frontend (VITE_ prefix - accessible in browser) ───────────────────────────
VITE_MIDTRANS_IS_PRODUCTION=false
VITE_MIDTRANS_CLIENT_KEY=Mid-client-xxxxxxxxxxxxxxxxxxxx

# Email yang secara otomatis mendapat role SUPER_ADMIN saat pertama kali register
VITE_SUPER_ADMIN_EMAIL=admin@yourdomain.com

# URL API backend (sesuaikan jika deploy ke server)
VITE_API_URL=http://localhost:5000/api

# ─── Resend Email (OTP & transactional emails) ───────────────────────────────
# Untuk development, pakai sender bawaan Resend: onboarding@resend.dev
# Untuk production, ganti dengan domain kamu yang SUDAH verified di Resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=Eventra <onboarding@resend.dev>

# Opsional (development): paksa semua email dikirim ke inbox owner Resend
# Berguna saat akun Resend masih mode testing (belum verify domain)
RESEND_DEV_REDIRECT_TO=owner-email@gmail.com
